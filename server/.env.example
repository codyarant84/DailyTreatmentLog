PORT=3001

# Email (Resend) — get API key from resend.com
RESEND_API_KEY=re_your_api_key_here

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# AWS RDS Database
DATABASE_URL=postgresql://fieldside:YOUR_RDS_PASSWORD@your-rds-host.rds.amazonaws.com:5432/postgres?sslmode=require

# JWT Auth
JWT_SECRET=your-64-char-random-secret-here

# AWS S3
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-2
S3_BUCKET_NAME=fieldside-logos

# AWS ECR
ECR_REGISTRY=your-account-id.dkr.ecr.us-east-2.amazonaws.com
ECR_REPOSITORY=fieldside-server
