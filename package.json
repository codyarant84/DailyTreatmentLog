{
  "name": "daily-treatment-log",
  "version": "1.0.0",
  "description": "Daily athletic training treatment log app",
  "private": true,
  "type": "module",
  "scripts": {
    "dev":         "concurrently \"npm run server\" \"npm run client\"",
    "server":      "npm --prefix server run dev",
    "client":      "npm --prefix client run dev",
    "build":       "cd client && npm install && npm run build",
    "install:all": "npm install && npm --prefix server install && npm --prefix client install"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@aws-sdk/s3-request-presigner": "^3.1029.0",
    "@supabase/supabase-js": "^2.45.4",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "resend": "^6.12.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
